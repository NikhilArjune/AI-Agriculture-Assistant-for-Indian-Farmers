# ─── App ─────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-this-to-a-random-64-char-secret
DEBUG=true

# ─── MongoDB ─────────────────────────────────────────────────────────
MONGO_URI=mongodb://admin:changeme@localhost:27017/agri_db?authSource=admin
MONGO_DB_NAME=agri_db

# ─── Redis ───────────────────────────────────────────────────────────
REDIS_URL=redis://:changeme@localhost:6379/0

# ─── Qdrant ──────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=agri_knowledge

# ─── LLM Providers ───────────────────────────────────────────────────
GROQ_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# Primary LLM config
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# ─── Embeddings ──────────────────────────────────────────────────────
EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2

# ─── STT / TTS ───────────────────────────────────────────────────────
STT_MODEL=whisper-large-v3-turbo
TTS_PROVIDER=groq
TTS_MODEL=canopylabs/orpheus-v1-english
TTS_VOICE=autumn

# ─── Auth / JWT ──────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── File Storage ────────────────────────────────────────────────────
STORAGE_BACKEND=local
UPLOAD_DIR=./uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=ap-south-1

# ─── External APIs ───────────────────────────────────────────────────
OPENWEATHER_API_KEY=
AGMARKNET_API_KEY=
MYSCHEME_API_KEY=
MSG91_AUTH_KEY=
FCM_SERVER_KEY=

# ─── Celery ──────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://:changeme@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:changeme@localhost:6379/2

# ─── LangSmith ───────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=agri-ai-platform

# ─── Sentry ──────────────────────────────────────────────────────────
SENTRY_DSN=

# ─── CORS ────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80
